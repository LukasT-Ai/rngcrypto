# RnGcrYptO Environment Variables
# Copy to .env.local and fill in values

# FRED API (free, get key at https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=DEMO_KEY

# Finnhub (free, get key at https://finnhub.io/register)
FINNHUB_API_KEY=
NEXT_PUBLIC_FINNHUB_KEY=

# YouTube Data API v3 (free, get key at https://console.cloud.google.com)
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# Beehiiv Newsletter (get from https://app.beehiiv.com/settings/integrations)
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# Anthropic Claude API (for auto-tweet bot, https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Twitter/X API (for auto-tweet bot, https://developer.twitter.com)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# Beehiiv RSS URL (for auto-tweet bot reading newsletter)
BEEHIIV_RSS_URL=

# Ascend stats push sync (shared secret between ascend-agent and this app)
ASCEND_SYNC_TOKEN=
